#cloud-config

package_update: true
package_upgrade: false

packages:
  - ca-certificates
  - curl
  - wget
  - unzip
  - zip
  - rsync
  - file
  - less
  - vim
  - bash
  - zsh
  - git
  - jq
  - openssh-client
  - tmux
  - ripgrep
  - build-essential
  - clang
  - lldb
  - lld
  - cmake
  - ninja-build
  - pkg-config
  - python3
  - python3-pip
  - python3-venv
  - gnupg
  - lsb-release
  - util-linux
  - fail2ban

write_files:
  - path: /etc/ssh/sshd_config.d/99-hardening.conf
    permissions: "0644"
    content: |
      PasswordAuthentication no
      PermitRootLogin prohibit-password
      ChallengeResponseAuthentication no
      KbdInteractiveAuthentication no
      X11Forwarding no

  - path: /etc/profile.d/dev-bootstrap.sh
    permissions: "0644"
    content: |
      export CODEX_HOME=/root/.codex
      export PATH="/root/.local/bin:${PATH}"

      if [ -n "@GIT_USER_NAME_B64@" ]; then
        export GIT_USER_NAME="$(printf '%s' '@GIT_USER_NAME_B64@' | base64 -d)"
        export GIT_AUTHOR_NAME="$GIT_USER_NAME"
        export GIT_COMMITTER_NAME="$GIT_USER_NAME"
      fi

      if [ -n "@GIT_USER_EMAIL_B64@" ]; then
        export GIT_USER_EMAIL="$(printf '%s' '@GIT_USER_EMAIL_B64@' | base64 -d)"
        export GIT_AUTHOR_EMAIL="$GIT_USER_EMAIL"
        export GIT_COMMITTER_EMAIL="$GIT_USER_EMAIL"
      fi

  - path: /etc/fail2ban/jail.d/sshd-local.conf
    permissions: "0644"
    content: |
      [sshd]
      enabled = true
      backend = systemd

  - path: /usr/local/sbin/dev-bootstrap.sh
    permissions: "0755"
    content: |
      #!/usr/bin/env bash
      set -euo pipefail

      log() {
        echo "[dev-bootstrap] $*"
      }

      # cloud-init may execute with a minimal environment where HOME is unset.
      # git --global requires HOME to resolve ~/.gitconfig.
      export HOME="${HOME:-/root}"
      export USER="${USER:-root}"

      resolve_template_value() {
        local value="$1"
        local default_value="$2"
        if [[ -z "${value}" || "${value}" =~ ^@[^@]+@$ ]]; then
          printf '%s' "${default_value}"
          return 0
        fi
        printf '%s' "${value}"
      }

      NODE_MAJOR="$(resolve_template_value "@NODE_MAJOR@" "@NODE_MAJOR@")"
      CODEX_VERSION="$(resolve_template_value "@CODEX_VERSION@" "@CODEX_VERSION@")"
      CLAUDE_CODE_VERSION="$(resolve_template_value "@CLAUDE_CODE_VERSION@" "@CLAUDE_CODE_VERSION@")"
      BR_VERSION="$(resolve_template_value "@BR_VERSION@" "@BR_VERSION@")"
      BV_VERSION="$(resolve_template_value "@BV_VERSION@" "@BV_VERSION@")"
      PNPM_VERSION="$(resolve_template_value "@PNPM_VERSION@" "@PNPM_VERSION@")"
      PLAYWRIGHT_MCP_VERSION="$(resolve_template_value "@PLAYWRIGHT_MCP_VERSION@" "@PLAYWRIGHT_MCP_VERSION@")"
      PLAYWRIGHT_VERSION="$(resolve_template_value "@PLAYWRIGHT_VERSION@" "@PLAYWRIGHT_VERSION@")"
      NOTIFY_ENABLED_DEFAULT="$(resolve_template_value "@NOTIFY_ENABLED@" "@NOTIFY_ENABLED@")"
      NOTIFY_MIN_INTERVAL_SEC_DEFAULT="$(resolve_template_value "@NOTIFY_MIN_INTERVAL_SEC@" "@NOTIFY_MIN_INTERVAL_SEC@")"
      NOTIFY_INCLUDE_SNIPPET_DEFAULT="$(resolve_template_value "@NOTIFY_INCLUDE_SNIPPET@" "@NOTIFY_INCLUDE_SNIPPET@")"
      CODEX_CONFIG_TOML_B64="$(resolve_template_value "@CODEX_CONFIG_TOML_B64@" "@CODEX_CONFIG_TOML_B64@")"
      CLAUDE_SETTINGS_JSON_B64="$(resolve_template_value "@CLAUDE_SETTINGS_JSON_B64@" "@CLAUDE_SETTINGS_JSON_B64@")"
      CLAUDE_KEYBINDINGS_JSON_B64="$(resolve_template_value "@CLAUDE_KEYBINDINGS_JSON_B64@" "@CLAUDE_KEYBINDINGS_JSON_B64@")"
      CLAUDE_MCP_JSON_B64="$(resolve_template_value "@CLAUDE_MCP_JSON_B64@" "@CLAUDE_MCP_JSON_B64@")"
      NPMRC_B64="$(resolve_template_value "@NPMRC_B64@" "@NPMRC_B64@")"
      NVMRC_B64="$(resolve_template_value "@NVMRC_B64@" "@NVMRC_B64@")"
      SHELL_CORE_ZSH_B64="$(resolve_template_value "@SHELL_CORE_ZSH_B64@" "@SHELL_CORE_ZSH_B64@")"
      GIT_USER_NAME_B64="$(resolve_template_value "@GIT_USER_NAME_B64@" "")"
      GIT_USER_EMAIL_B64="$(resolve_template_value "@GIT_USER_EMAIL_B64@" "")"

      decode_b64() {
        if [[ -z "$1" ]]; then
          return 0
        fi
        printf '%s' "$1" | base64 -d 2>/dev/null
      }

      GIT_USER_NAME="$(decode_b64 "$GIT_USER_NAME_B64")"
      GIT_USER_EMAIL="$(decode_b64 "$GIT_USER_EMAIL_B64")"

      decode_b64_to_file() {
        local b64_value dest_path mode
        b64_value="$1"
        dest_path="$2"
        mode="$3"

        mkdir -p "$(dirname "${dest_path}")"
        if ! printf '%s' "${b64_value}" | base64 -d > "${dest_path}"; then
          echo "Failed to decode embedded config for ${dest_path}" >&2
          exit 1
        fi
        chmod "${mode}" "${dest_path}"
      }

      install_baseline_config_files() {
        decode_b64_to_file "${NPMRC_B64}" "/root/.npmrc" 0644
        decode_b64_to_file "${NVMRC_B64}" "/root/.nvmrc" 0644
        decode_b64_to_file "${NVMRC_B64}" "/workspace/main/.nvmrc" 0644
        decode_b64_to_file "${CODEX_CONFIG_TOML_B64}" "/root/.codex/config.toml" 0644
        decode_b64_to_file "${CLAUDE_SETTINGS_JSON_B64}" "/root/.claude/settings.json" 0644
        decode_b64_to_file "${CLAUDE_KEYBINDINGS_JSON_B64}" "/root/.claude/keybindings.json" 0644
        decode_b64_to_file "${CLAUDE_MCP_JSON_B64}" "/root/.claude/mcp.json" 0644
        decode_b64_to_file "${SHELL_CORE_ZSH_B64}" "/root/.config/carl/zsh/core.zsh" 0644

        if ! jq -e . /root/.claude/settings.json >/dev/null 2>&1; then
          echo "Embedded Claude settings JSON is invalid." >&2
          exit 1
        fi

        if ! jq -e . /root/.claude/keybindings.json >/dev/null 2>&1; then
          echo "Embedded Claude keybindings JSON is invalid." >&2
          exit 1
        fi

        if ! jq -e . /root/.claude/mcp.json >/dev/null 2>&1; then
          echo "Embedded Claude MCP JSON is invalid." >&2
          exit 1
        fi
      }

      ensure_carl_zshrc_source_block() {
        local zshrc source_line begin_marker end_marker tmp_file
        zshrc="/root/.zshrc"
        source_line='[[ -f "$HOME/.config/carl/zsh/core.zsh" ]] && source "$HOME/.config/carl/zsh/core.zsh"'
        begin_marker='# >>> CARL ZSH CORE >>>'
        end_marker='# <<< CARL ZSH CORE <<<'

        touch "${zshrc}"
        tmp_file="$(mktemp)"

        awk \
          -v begin_marker="${begin_marker}" \
          -v end_marker="${end_marker}" \
          -v source_line="${source_line}" \
          '
            BEGIN { in_block = 0; block_written = 0 }
            $0 == begin_marker {
              if (block_written == 0) {
                print begin_marker
                print source_line
                print end_marker
                block_written = 1
              }
              in_block = 1
              next
            }
            $0 == end_marker {
              in_block = 0
              next
            }
            {
              if (!in_block) {
                print
              }
            }
            END {
              if (block_written == 0) {
                if (NR > 0) {
                  print ""
                }
                print begin_marker
                print source_line
                print end_marker
              }
            }
          ' "${zshrc}" > "${tmp_file}"

        mv "${tmp_file}" "${zshrc}"
      }

      ensure_zsh_as_default_shell() {
        local zsh_bin current_shell
        zsh_bin="$(command -v zsh || true)"
        if [[ -z "${zsh_bin}" ]]; then
          echo "zsh is required but was not found." >&2
          return 1
        fi

        current_shell="$(getent passwd root 2>/dev/null | cut -d: -f7 || true)"
        if [[ -z "${current_shell}" ]]; then
          current_shell="$(awk -F: '$1=="root"{print $7}' /etc/passwd)"
        fi
        if [[ "${current_shell}" == "${zsh_bin}" ]]; then
          return 0
        fi

        if chsh -s "${zsh_bin}" root >/dev/null 2>&1; then
          log "Set default shell to ${zsh_bin} for root."
        else
          log "Warning: failed to set default shell to ${zsh_bin} for root."
        fi
      }

      ensure_ssh_keypair() {
        local ssh_dir private_key public_key key_comment host_name
        ssh_dir="/root/.ssh"
        private_key="${ssh_dir}/id_ed25519"
        public_key="${private_key}.pub"

        mkdir -p "${ssh_dir}"
        chmod 700 "${ssh_dir}"

        if [[ -n "${GIT_USER_EMAIL}" ]]; then
          key_comment="${GIT_USER_EMAIL}"
        else
          host_name="$(hostname -f 2>/dev/null || hostname 2>/dev/null || echo "localhost")"
          key_comment="root@${host_name}"
        fi

        if [[ -f "${private_key}" ]]; then
          log "SSH key already exists at ${private_key}; preserving existing key"
        else
          log "Generating SSH key at ${private_key}"
          ssh-keygen -t ed25519 -a 64 -f "${private_key}" -N "" -C "${key_comment}"
        fi

        if [[ ! -f "${public_key}" ]]; then
          log "Public key missing at ${public_key}; regenerating from private key"
          ssh-keygen -y -f "${private_key}" > "${public_key}"
        fi

        chmod 600 "${private_key}"
        chmod 644 "${public_key}"
      }

      validate_notify_defaults() {
        case "${NOTIFY_ENABLED_DEFAULT,,}" in
          0|1|true|false|yes|no|on|off) ;;
          *)
            echo "Invalid NOTIFY_ENABLED value: ${NOTIFY_ENABLED_DEFAULT}" >&2
            exit 1
            ;;
        esac

        case "${NOTIFY_INCLUDE_SNIPPET_DEFAULT,,}" in
          0|1|true|false|yes|no|on|off) ;;
          *)
            echo "Invalid NOTIFY_INCLUDE_SNIPPET value: ${NOTIFY_INCLUDE_SNIPPET_DEFAULT}" >&2
            exit 1
            ;;
        esac

        if [[ ! "${NOTIFY_MIN_INTERVAL_SEC_DEFAULT}" =~ ^[0-9]+$ ]]; then
          echo "NOTIFY_MIN_INTERVAL_SEC must be a non-negative integer: ${NOTIFY_MIN_INTERVAL_SEC_DEFAULT}" >&2
          exit 1
        fi
      }

      install_carl_notify_script() {
        cat > /usr/local/bin/carl-notify <<'CARL_NOTIFY'
      #!/usr/bin/env bash
      set -euo pipefail
      
      log() {
        printf '[carl-notify] %s\n' "$*" >&2
      }
      
      need_cmd() {
        command -v "$1" >/dev/null 2>&1 || {
          log "Missing command: $1"
          exit 1
        }
      }
      
      normalize_bool() {
        case "$1" in
          1|true|TRUE|yes|YES|on|ON) printf '1' ;;
          0|false|FALSE|no|NO|off|OFF) printf '0' ;;
          *)
            log "Invalid boolean value: $1"
            exit 1
            ;;
        esac
      }
      
      hash_sha256() {
        if command -v sha256sum >/dev/null 2>&1; then
          sha256sum | awk '{print $1}'
          return 0
        fi
        shasum -a 256 | awk '{print $1}'
      }
      
      need_cmd jq
      need_cmd curl
      need_cmd hostname
      
      source_name="${1:-}"
      if [[ -z "${source_name}" ]]; then
        log "Usage: carl-notify <codex|claude> [json-payload]"
        exit 1
      fi
      shift || true
      
      default_enabled="$(normalize_bool "${CARL_NOTIFY_ENABLED_DEFAULT:-1}")"
      default_interval="${CARL_NOTIFY_MIN_INTERVAL_SEC_DEFAULT:-120}"
      default_include="$(normalize_bool "${CARL_NOTIFY_INCLUDE_SNIPPET_DEFAULT:-1}")"
      
      notify_enabled="$(normalize_bool "${NOTIFY_ENABLED:-${default_enabled}}")"
      notify_interval="${NOTIFY_MIN_INTERVAL_SEC:-${default_interval}}"
      notify_include="$(normalize_bool "${NOTIFY_INCLUDE_SNIPPET:-${default_include}}")"
      
      if [[ "${notify_enabled}" != "1" ]]; then
        exit 0
      fi
      
      if [[ ! "${notify_interval}" =~ ^[0-9]+$ ]]; then
        log "NOTIFY_MIN_INTERVAL_SEC must be a non-negative integer"
        exit 1
      fi
      
      secrets_file="${CARL_SECRETS_FILE:-$HOME/.config/carl/secrets.env}"
      if [[ -f "${secrets_file}" ]]; then
        set -a
        # shellcheck disable=SC1090
        source "${secrets_file}"
        set +a
      fi
      
      if [[ -z "${SLACK_WEBHOOK_URL:-}" ]]; then
        log "SLACK_WEBHOOK_URL is required in ${secrets_file}"
        exit 2
      fi
      
      raw_payload=""
      if [[ $# -gt 0 ]]; then
        raw_payload="$*"
      elif [[ ! -t 0 ]]; then
        raw_payload="$(cat || true)"
      fi
      
      if [[ -z "${raw_payload}" ]]; then
        payload='{}'
      elif printf '%s' "${raw_payload}" | jq -e . >/dev/null 2>&1; then
        payload="${raw_payload}"
      else
        payload="$(jq -n --arg message "${raw_payload}" '{message: $message}')"
      fi
      
      event="$(printf '%s' "${payload}" | jq -r '.hook_event_name // .event // .event_name // .type // .reason // "notification"')"
      message="$(printf '%s' "${payload}" | jq -r '.message // .title // .summary // .reason // .["last-assistant-message"] // .last_assistant_message // empty' | tr '\r\n' ' ' | sed -e 's/[[:space:]]\+/ /g' -e 's/^ //' -e 's/ $//')"
      cwd_hint="$(printf '%s' "${payload}" | jq -r '.cwd // .workspace_path // .workspace_root // .path // empty')"
      session_hint="$(printf '%s' "${payload}" | jq -r '.session_id // .["turn-id"] // .turn_id // .conversation_id // .request_id // .id // empty')"
      
      if [[ -z "${cwd_hint}" ]]; then
        cwd_hint="$(pwd)"
      fi
      
      cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/carl-notify"
      state_file="${cache_dir}/last_event"
      mkdir -p "${cache_dir}"
      chmod 700 "${cache_dir}"
      
      dedupe_key="$(printf '%s|%s|%s|%s|%s' "${source_name}" "${event}" "${cwd_hint}" "${session_hint}" "${message}" | hash_sha256)"
      now_ts="$(date +%s)"
      if [[ -f "${state_file}" ]]; then
        read -r prev_ts prev_key < "${state_file}" || true
        if [[ "${prev_key:-}" == "${dedupe_key}" && "${prev_ts:-}" =~ ^[0-9]+$ ]]; then
          if (( now_ts - prev_ts < notify_interval )); then
            exit 0
          fi
        fi
      fi
      
      printf '%s %s\n' "${now_ts}" "${dedupe_key}" > "${state_file}"
      chmod 600 "${state_file}"
      
      host_name="$(hostname -f 2>/dev/null || hostname 2>/dev/null || echo unknown-host)"
      user_name="${USER:-unknown-user}"
      now_utc="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
      
      text_lines=(
        "CARL attention needed: ${source_name} (${event})"
        "host=${host_name}"
        "user=${user_name}"
        "cwd=${cwd_hint}"
        "time_utc=${now_utc}"
      )
      
      if [[ -n "${session_hint}" ]]; then
        text_lines+=("session=${session_hint}")
      fi
      
      if [[ "${notify_include}" == "1" && -n "${message}" ]]; then
        text_lines+=("message=$(printf '%.240s' "${message}")")
      fi
      
      slack_payload="$(jq -n --arg text "$(printf '%s\n' "${text_lines[@]}")" '{text: $text}')"
      curl -fsS -X POST -H 'Content-Type: application/json' --data "${slack_payload}" "${SLACK_WEBHOOK_URL}" >/dev/null
      CARL_NOTIFY

        chmod 0755 /usr/local/bin/carl-notify
      }

      configure_codex_notify() {
        local config_file notify_line tui_line tmp_file
        config_file="/root/.codex/config.toml"
        mkdir -p /root/.codex
        if [[ ! -f "${config_file}" ]]; then
          : > "${config_file}"
        fi

        notify_line="notify = [\"/usr/bin/env\", \"CARL_NOTIFY_ENABLED_DEFAULT=${NOTIFY_ENABLED_DEFAULT}\", \"CARL_NOTIFY_MIN_INTERVAL_SEC_DEFAULT=${NOTIFY_MIN_INTERVAL_SEC_DEFAULT}\", \"CARL_NOTIFY_INCLUDE_SNIPPET_DEFAULT=${NOTIFY_INCLUDE_SNIPPET_DEFAULT}\", \"/usr/local/bin/carl-notify\", \"codex\"]"
        tui_line="tui.notifications = true"

        tmp_file="$(mktemp)"
        awk \
          -v notify_line="${notify_line}" \
          -v tui_line="${tui_line}" \
          '
            function emit_root_keys() {
              if (notify_seen == 0) {
                print notify_line
                notify_seen = 1
              }
              if (tui_seen == 0) {
                print tui_line
                tui_seen = 1
              }
              root_emitted = 1
            }
            BEGIN { notify_seen = 0; tui_seen = 0; root_emitted = 0 }
            /^[[:space:]]*notify[[:space:]]*=/ {
              next
            }
            /^[[:space:]]*tui\.notifications[[:space:]]*=/ {
              next
            }
            /^[[:space:]]*\[[^]]+\][[:space:]]*$/ {
              if (root_emitted == 0) {
                emit_root_keys()
                print ""
              }
              print
              next
            }
            { print }
            END {
              if (root_emitted == 0) { emit_root_keys() }
            }
          ' "${config_file}" > "${tmp_file}"
        mv "${tmp_file}" "${config_file}"
      }

      configure_claude_notify() {
        local config_file escaped_notify_bin command_string tmp_file
        config_file="/root/.claude/settings.json"
        mkdir -p /root/.claude
        if [[ ! -f "${config_file}" ]]; then
          printf '{}\n' > "${config_file}"
        fi

        if ! jq -e . "${config_file}" >/dev/null 2>&1; then
          echo "Invalid JSON in ${config_file}; skipping Claude notify hook config." >&2
          return 0
        fi

        escaped_notify_bin="$(printf '%q' /usr/local/bin/carl-notify)"
        command_string="CARL_NOTIFY_ENABLED_DEFAULT=${NOTIFY_ENABLED_DEFAULT} CARL_NOTIFY_MIN_INTERVAL_SEC_DEFAULT=${NOTIFY_MIN_INTERVAL_SEC_DEFAULT} CARL_NOTIFY_INCLUDE_SNIPPET_DEFAULT=${NOTIFY_INCLUDE_SNIPPET_DEFAULT} ${escaped_notify_bin} claude"
        tmp_file="$(mktemp)"

        jq --arg cmd "${command_string}" '
          . as $root
          | if ($root | type) == "object" then $root else {} end
          | .hooks = (.hooks // {})
          | reduce ["Notification","Stop"][] as $event (
              .;
              .hooks[$event] = (
                if (.hooks[$event] | type) == "array"
                then .hooks[$event]
                else []
                end
              )
              | if ([ .hooks[$event][]?.hooks[]? | select(.type == "command" and .command == $cmd) ] | length) > 0
                then .
                else .hooks[$event] += [
                  {
                    "hooks": [
                      {
                        "type": "command",
                        "command": $cmd
                      }
                    ]
                  }
                ]
                end
            )
        ' "${config_file}" > "${tmp_file}"

        mv "${tmp_file}" "${config_file}"
      }

      export DEBIAN_FRONTEND=noninteractive

      log "Preparing workspace and root tool directories"
      mkdir -p /workspace /workspace/main
      mkdir -p /root/.codex /root/.cache /root/.config /root/.local/share /root/.local/bin /root/.npm
      chmod 700 /root/.codex /root/.cache /root/.config /root/.local /root/.local/share /root/.npm

      if [[ -n "${GIT_USER_NAME}" && -n "${GIT_USER_EMAIL}" ]]; then
        log "Configuring root git identity from injected environment values"
        if ! git config --file /root/.gitconfig user.name "${GIT_USER_NAME}" \
          || ! git config --file /root/.gitconfig user.email "${GIT_USER_EMAIL}"; then
          log "Warning: failed to write /root/.gitconfig; continuing bootstrap"
        fi
      else
        log "Skipping git identity config (GIT_USER_NAME/GIT_USER_EMAIL not both provided)"
      fi

      ensure_ssh_keypair
      validate_notify_defaults
      install_carl_notify_script
      install_baseline_config_files
      ensure_carl_zshrc_source_block
      ensure_zsh_as_default_shell

      log "Installing Node.js ${NODE_MAJOR}.x from NodeSource"
      mkdir -p /etc/apt/keyrings
      curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
        | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg
      chmod 0644 /etc/apt/keyrings/nodesource.gpg
      echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" \
        > /etc/apt/sources.list.d/nodesource.list
      apt-get update
      apt-get install -y --no-install-recommends nodejs

      log "Installing Visual Studio Code (stable)"
      if command -v debconf-set-selections >/dev/null 2>&1; then
        echo "code code/add-microsoft-repo boolean true" | debconf-set-selections
      fi
      tmp_vscode_key="$(mktemp)"
      curl -fsSL https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor > "${tmp_vscode_key}"
      install -D -o root -g root -m 0644 "${tmp_vscode_key}" /usr/share/keyrings/microsoft.gpg
      rm -f "${tmp_vscode_key}"
      cat > /etc/apt/sources.list.d/vscode.sources <<'EOF_VSCODE_REPO'
Types: deb
URIs: https://packages.microsoft.com/repos/code
Suites: stable
Components: main
Architectures: amd64,arm64,armhf
Signed-By: /usr/share/keyrings/microsoft.gpg
EOF_VSCODE_REPO
      apt-get update
      apt-get install -y --no-install-recommends code
      code --version

      log "Installing codex CLI (${CODEX_VERSION})"
      npm install -g "@openai/codex@${CODEX_VERSION}"
      codex --version

      log "Installing Claude Code via native installer (${CLAUDE_CODE_VERSION})"
      curl -fsSL https://claude.ai/install.sh | bash -s -- "${CLAUDE_CODE_VERSION}"
      export PATH="/root/.local/bin:${PATH}"
      claude --version
      configure_codex_notify
      configure_claude_notify

      log "Installing pnpm (${PNPM_VERSION})"
      npm install -g "pnpm@${PNPM_VERSION}"
      pnpm --version

      log "Installing Playwright tooling (mcp=${PLAYWRIGHT_MCP_VERSION}, playwright=${PLAYWRIGHT_VERSION})"
      npm install -g "@playwright/mcp@${PLAYWRIGHT_MCP_VERSION}" "playwright@${PLAYWRIGHT_VERSION}"
      npx --yes playwright install --with-deps chromium
      npx --yes playwright --version

      log "Resolving Chromium symlink under /root/.local/bin/chromium"
      CHROME_BIN="$(find /root/.cache/ms-playwright -type f -name chrome -path "*/chromium-*/*" | head -n1 || true)"
      if [[ -z "${CHROME_BIN}" ]]; then
        echo "Could not locate Playwright Chromium binary under /root/.cache/ms-playwright" >&2
        exit 1
      fi
      CHROME_DIR="$(dirname "${CHROME_BIN}")"
      ln -sfn "${CHROME_DIR}" /root/.local/playwright-chrome
      ln -sfn "${CHROME_BIN}" /root/.local/bin/chromium
      /root/.local/bin/chromium --version

      log "Installing br (${BR_VERSION})"
      arch="$(dpkg --print-architecture)"
      case "${arch}" in
        arm64) br_arch="arm64" ;;
        amd64) br_arch="amd64" ;;
        *)
          echo "Unsupported architecture for br: ${arch}" >&2
          exit 1
          ;;
      esac

      br_tag="v${BR_VERSION}"
      br_tarball="br-${br_tag}-linux_${br_arch}.tar.gz"
      tmp_dir="$(mktemp -d)"
      curl -fsSL "https://github.com/Dicklesworthstone/beads_rust/releases/download/${br_tag}/${br_tarball}" -o "${tmp_dir}/br.tar.gz"
      tar -xzf "${tmp_dir}/br.tar.gz" -C "${tmp_dir}"
      br_bin="$(find "${tmp_dir}" -type f -name br | head -n1)"
      test -n "${br_bin}"
      install -m 0755 "${br_bin}" /usr/local/bin/br
      rm -rf "${tmp_dir}"
      br --version

      log "Installing bv (${BV_VERSION})"
      arch="$(dpkg --print-architecture)"
      case "${arch}" in
        arm64) bv_arch="arm64" ;;
        amd64) bv_arch="amd64" ;;
        *)
          echo "Unsupported architecture for bv: ${arch}" >&2
          exit 1
          ;;
      esac

      bv_tag="v${BV_VERSION}"
      bv_release_api="https://api.github.com/repos/Dicklesworthstone/beads_viewer/releases/tags/${bv_tag}"
      bv_asset_url="$(curl -fsSL "${bv_release_api}" \
        | jq -r --arg arch "${bv_arch}" '.assets[]?.browser_download_url | select(test("bv"; "i") and test("linux"; "i") and test($arch; "i") and test("\\.(tar\\.gz|tgz)$"; "i"))' \
        | head -n1 || true)"

      if [[ -z "${bv_asset_url}" ]]; then
        echo "Could not find a Linux ${bv_arch} release asset for bv ${bv_tag}" >&2
        exit 1
      fi

      tmp_dir="$(mktemp -d)"
      curl -fsSL "${bv_asset_url}" -o "${tmp_dir}/bv.tar.gz"
      tar -xzf "${tmp_dir}/bv.tar.gz" -C "${tmp_dir}"
      bv_bin="$(find "${tmp_dir}" -type f -name bv | head -n1 || true)"
      if [[ -z "${bv_bin}" ]]; then
        echo "Downloaded bv archive did not contain a bv binary." >&2
        exit 1
      fi
      install -m 0755 "${bv_bin}" /usr/local/bin/bv
      rm -rf "${tmp_dir}"
      bv --version

      tmux -V
      command -v carl-notify >/dev/null

      log "Bootstrap complete"

runcmd:
  - /usr/local/sbin/dev-bootstrap.sh
  - systemctl enable --now fail2ban || (journalctl -u fail2ban --no-pager -n 100 || true)
  # Intentionally: no ssh restart during bootstrap iteration
