#cloud-config

package_update: true
package_upgrade: false

packages:
  - ca-certificates
  - curl
  - wget
  - unzip
  - zip
  - rsync
  - file
  - less
  - vim
  - bash
  - git
  - openssh-client
  - tmux
  - ripgrep
  - build-essential
  - clang
  - lldb
  - lld
  - cmake
  - ninja-build
  - pkg-config
  - python3
  - python3-pip
  - python3-venv
  - gnupg
  - lsb-release
  - util-linux
  - fail2ban

write_files:
  - path: /etc/ssh/sshd_config.d/99-hardening.conf
    permissions: "0644"
    content: |
      PasswordAuthentication no
      PermitRootLogin prohibit-password
      ChallengeResponseAuthentication no
      KbdInteractiveAuthentication no
      X11Forwarding no

  - path: /etc/profile.d/dev-bootstrap.sh
    permissions: "0644"
    content: |
      export CODEX_HOME=/root/.codex
      export PATH="/root/.local/bin:${PATH}"

      if [ -n "@GIT_USER_NAME_B64@" ]; then
        export GIT_USER_NAME="$(printf '%s' '@GIT_USER_NAME_B64@' | base64 -d)"
        export GIT_AUTHOR_NAME="$GIT_USER_NAME"
        export GIT_COMMITTER_NAME="$GIT_USER_NAME"
      fi

      if [ -n "@GIT_USER_EMAIL_B64@" ]; then
        export GIT_USER_EMAIL="$(printf '%s' '@GIT_USER_EMAIL_B64@' | base64 -d)"
        export GIT_AUTHOR_EMAIL="$GIT_USER_EMAIL"
        export GIT_COMMITTER_EMAIL="$GIT_USER_EMAIL"
      fi

  - path: /etc/fail2ban/jail.d/sshd-local.conf
    permissions: "0644"
    content: |
      [sshd]
      enabled = true
      backend = systemd

  - path: /usr/local/sbin/dev-bootstrap.sh
    permissions: "0755"
    content: |
      #!/usr/bin/env bash
      set -euo pipefail

      log() {
        echo "[dev-bootstrap] $*"
      }

      # cloud-init may execute with a minimal environment where HOME is unset.
      # git --global requires HOME to resolve ~/.gitconfig.
      export HOME="${HOME:-/root}"
      export USER="${USER:-root}"

      resolve_template_value() {
        local value="$1"
        local default_value="$2"
        if [[ -z "${value}" || "${value}" =~ ^@[^@]+@$ ]]; then
          printf '%s' "${default_value}"
          return 0
        fi
        printf '%s' "${value}"
      }

      NODE_MAJOR="$(resolve_template_value "@NODE_MAJOR@" "@NODE_MAJOR@")"
      CODEX_VERSION="$(resolve_template_value "@CODEX_VERSION@" "@CODEX_VERSION@")"
      CLAUDE_CODE_VERSION="$(resolve_template_value "@CLAUDE_CODE_VERSION@" "@CLAUDE_CODE_VERSION@")"
      BR_VERSION="$(resolve_template_value "@BR_VERSION@" "@BR_VERSION@")"
      PNPM_VERSION="$(resolve_template_value "@PNPM_VERSION@" "@PNPM_VERSION@")"
      PLAYWRIGHT_MCP_VERSION="$(resolve_template_value "@PLAYWRIGHT_MCP_VERSION@" "@PLAYWRIGHT_MCP_VERSION@")"
      PLAYWRIGHT_VERSION="$(resolve_template_value "@PLAYWRIGHT_VERSION@" "@PLAYWRIGHT_VERSION@")"
      GIT_USER_NAME_B64="$(resolve_template_value "@GIT_USER_NAME_B64@" "")"
      GIT_USER_EMAIL_B64="$(resolve_template_value "@GIT_USER_EMAIL_B64@" "")"

      decode_b64() {
        if [[ -z "$1" ]]; then
          return 0
        fi
        printf '%s' "$1" | base64 -d 2>/dev/null
      }

      GIT_USER_NAME="$(decode_b64 "$GIT_USER_NAME_B64")"
      GIT_USER_EMAIL="$(decode_b64 "$GIT_USER_EMAIL_B64")"

      ensure_ssh_keypair() {
        local ssh_dir private_key public_key key_comment host_name
        ssh_dir="/root/.ssh"
        private_key="${ssh_dir}/id_ed25519"
        public_key="${private_key}.pub"

        mkdir -p "${ssh_dir}"
        chmod 700 "${ssh_dir}"

        if [[ -n "${GIT_USER_EMAIL}" ]]; then
          key_comment="${GIT_USER_EMAIL}"
        else
          host_name="$(hostname -f 2>/dev/null || hostname 2>/dev/null || echo "localhost")"
          key_comment="root@${host_name}"
        fi

        if [[ -f "${private_key}" ]]; then
          log "SSH key already exists at ${private_key}; preserving existing key"
        else
          log "Generating SSH key at ${private_key}"
          ssh-keygen -t ed25519 -a 64 -f "${private_key}" -N "" -C "${key_comment}"
        fi

        if [[ ! -f "${public_key}" ]]; then
          log "Public key missing at ${public_key}; regenerating from private key"
          ssh-keygen -y -f "${private_key}" > "${public_key}"
        fi

        chmod 600 "${private_key}"
        chmod 644 "${public_key}"
      }

      export DEBIAN_FRONTEND=noninteractive

      log "Preparing workspace and root tool directories"
      mkdir -p /workspace /workspace/main
      mkdir -p /root/.codex /root/.cache /root/.config /root/.local/share /root/.local/bin /root/.npm
      chmod 700 /root/.codex /root/.cache /root/.config /root/.local /root/.local/share /root/.npm

      if [[ -n "${GIT_USER_NAME}" && -n "${GIT_USER_EMAIL}" ]]; then
        log "Configuring root git identity from injected environment values"
        if ! git config --file /root/.gitconfig user.name "${GIT_USER_NAME}" \
          || ! git config --file /root/.gitconfig user.email "${GIT_USER_EMAIL}"; then
          log "Warning: failed to write /root/.gitconfig; continuing bootstrap"
        fi
      else
        log "Skipping git identity config (GIT_USER_NAME/GIT_USER_EMAIL not both provided)"
      fi

      ensure_ssh_keypair

      log "Installing Node.js ${NODE_MAJOR}.x from NodeSource"
      mkdir -p /etc/apt/keyrings
      curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
        | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg
      chmod 0644 /etc/apt/keyrings/nodesource.gpg
      echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" \
        > /etc/apt/sources.list.d/nodesource.list
      apt-get update
      apt-get install -y --no-install-recommends nodejs

      log "Installing codex CLI (${CODEX_VERSION})"
      npm install -g "@openai/codex@${CODEX_VERSION}"
      codex --version

      log "Installing Claude Code via native installer (${CLAUDE_CODE_VERSION})"
      curl -fsSL https://claude.ai/install.sh | bash -s -- "${CLAUDE_CODE_VERSION}"
      export PATH="/root/.local/bin:${PATH}"
      claude --version

      log "Installing pnpm (${PNPM_VERSION})"
      npm install -g "pnpm@${PNPM_VERSION}"
      pnpm --version

      log "Installing Playwright tooling (mcp=${PLAYWRIGHT_MCP_VERSION}, playwright=${PLAYWRIGHT_VERSION})"
      npm install -g "@playwright/mcp@${PLAYWRIGHT_MCP_VERSION}" "playwright@${PLAYWRIGHT_VERSION}"
      npx --yes playwright install --with-deps chromium
      npx --yes playwright --version

      log "Resolving Chromium symlink under /root/.local/bin/chromium"
      CHROME_BIN="$(find /root/.cache/ms-playwright -type f -name chrome -path "*/chromium-*/*" | head -n1 || true)"
      if [[ -z "${CHROME_BIN}" ]]; then
        echo "Could not locate Playwright Chromium binary under /root/.cache/ms-playwright" >&2
        exit 1
      fi
      CHROME_DIR="$(dirname "${CHROME_BIN}")"
      ln -sfn "${CHROME_DIR}" /root/.local/playwright-chrome
      ln -sfn "${CHROME_BIN}" /root/.local/bin/chromium
      /root/.local/bin/chromium --version

      log "Installing br (${BR_VERSION})"
      arch="$(dpkg --print-architecture)"
      case "${arch}" in
        arm64) br_arch="arm64" ;;
        amd64) br_arch="amd64" ;;
        *)
          echo "Unsupported architecture for br: ${arch}" >&2
          exit 1
          ;;
      esac

      br_tag="v${BR_VERSION}"
      br_tarball="br-${br_tag}-linux_${br_arch}.tar.gz"
      tmp_dir="$(mktemp -d)"
      curl -fsSL "https://github.com/Dicklesworthstone/beads_rust/releases/download/${br_tag}/${br_tarball}" -o "${tmp_dir}/br.tar.gz"
      tar -xzf "${tmp_dir}/br.tar.gz" -C "${tmp_dir}"
      br_bin="$(find "${tmp_dir}" -type f -name br | head -n1)"
      test -n "${br_bin}"
      install -m 0755 "${br_bin}" /usr/local/bin/br
      rm -rf "${tmp_dir}"
      br --version

      tmux -V

      log "Bootstrap complete"

runcmd:
  - /usr/local/sbin/dev-bootstrap.sh
  - systemctl enable --now fail2ban || (journalctl -u fail2ban --no-pager -n 100 || true)
  # Intentionally: no ssh restart during bootstrap iteration
