# Canonical repository configuration (non-secret only).
# This file is the single source of truth for pinned bootstrap versions and
# default droplet/runtime settings.
# Secrets/tool auth should be sourced from external systems, not stored here.

# Droplet config used by create-droplet.sh
DROPLET_NAME=devbox-1
REGION=nyc3
IMAGE=ubuntu-24-04-x64
SIZE=s-1vcpu-2gb

# Cloud-init source file rendered to /tmp at runtime by create-droplet.sh.
CLOUD_INIT_FILE=./linux/cloud-init.yaml

# Canonical pinned bootstrap versions (consumed by scripts/render-bootstrap-artifacts.sh)
NODE_MAJOR=24
CODEX_VERSION=0.104.0
CLAUDE_CODE_VERSION=stable
BR_VERSION=0.1.7
PNPM_VERSION=10.30.1
PLAYWRIGHT_MCP_VERSION=0.0.68
PLAYWRIGHT_VERSION=1.58.2

# Git identity is collected interactively at runtime by:
# - digitalOcean/create-droplet.sh
# - macos/bootstrap-mac.sh

# Shared state file used by create/destroy scripts
STATE_FILE=./.do-droplet.json

# Set one of these if you want to pin key selection.
# SSH_KEY_ID=123456
# SSH_KEY_NAME_MATCH=my-key-name
